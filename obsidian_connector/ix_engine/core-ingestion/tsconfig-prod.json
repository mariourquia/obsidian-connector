{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "declaration": true,
    "skipLibCheck": true,
    "typeRoots": ["../ix-cli/node_modules/@types"]
  },
  "include": ["src"],
  "exclude": ["src/__tests__"]
}
