{
  "name": "@ix/cli",
  "version": "0.6.0",
  "type": "module",
  "description": "Ix Memory — Persistent Memory for LLM Systems",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./client/*": "./dist/client/*",
    "./cli/*": "./dist/cli/*"
  },
  "bin": {
    "ix": "dist/cli/main.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "node scripts/build-core-ingestion.mjs && node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc",
    "test": "node scripts/build-core-ingestion.mjs && vitest run --exclude test/parser.test.ts && node test/parser.smoke.mjs",
    "dev": "node scripts/build-core-ingestion.mjs && tsx src/cli/main.ts"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "vite": ">=7.3.2 <8.0.0"
  }
}
