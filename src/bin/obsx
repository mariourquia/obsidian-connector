#!/usr/bin/env bash
# Wrapper for obsidian-connector CLI.
# Works from any shell (Desktop, Terminal, CI) without venv activation.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$SCRIPT_DIR"
while [ "$PROJECT_ROOT" != "/" ]; do
    [ -f "$PROJECT_ROOT/pyproject.toml" ] && break
    PROJECT_ROOT="$(dirname "$PROJECT_ROOT")"
done

VENV_PYTHON="$PROJECT_ROOT/.venv/bin/python3"
if [ ! -x "$VENV_PYTHON" ]; then
    echo "obsidian-connector: venv not found, creating automatically..." >&2
    SYSTEM_PYTHON=""
    for cmd in python3.14 python3.13 python3.12 python3.11 python3; do
        if command -v "$cmd" &>/dev/null; then
            ver=$("$cmd" -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')" 2>/dev/null || echo "0.0")
            major=$(echo "$ver" | cut -d. -f1); minor=$(echo "$ver" | cut -d. -f2)
            if [ "$major" -ge 3 ] && [ "$minor" -ge 11 ]; then SYSTEM_PYTHON="$cmd"; break; fi
        fi
    done
    if [ -z "$SYSTEM_PYTHON" ]; then
        echo "Error: Python 3.11+ not found. Install from https://www.python.org/downloads/" >&2; exit 1
    fi
    "$SYSTEM_PYTHON" -m venv "$PROJECT_ROOT/.venv" && "$PROJECT_ROOT/.venv/bin/pip" install --quiet -e "$PROJECT_ROOT" || {
        echo "Error: auto-setup failed" >&2; exit 1
    }
    echo "  Setup complete." >&2
fi
exec "$VENV_PYTHON" -m obsidian_connector.cli "$@"
