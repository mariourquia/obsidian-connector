#!/usr/bin/env bash
# MCP server wrapper for obsidian-connector.
# Launches the stdio MCP server using the repo's venv Python.
# Used by claude_desktop_config.json -- does not require venv activation.
SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
exec "${SCRIPT_DIR}/.venv/bin/python3" -m obsidian_connector.mcp_server "$@"
